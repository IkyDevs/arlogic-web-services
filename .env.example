# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-bot-token

# Telegram Channels (semua channel yang dipakai)
TELEGRAM_CHANNEL_ATTENDANCE=@channel
TELEGRAM_CHANNEL_SERVICE=@channel
TELEGRAM_CHANNEL_LAYANAN=@channel
TELEGRAM_CHANNEL_INVENTORY=@channel
TELEGRAM_CHANNEL_CLOSING=@channel
TELEGRAM_CHANNEL_CUSTOMER=@channel
TELEGRAM_CHANNEL_KASPIN=@channel
TELEGRAM_CHANNEL_TEKNISI_UPDATE=@channel
TELEGRAM_CHANNEL_QC_UPDATE=@channel
TELEGRAM_CHANNEL_BUKU_KAS=@channel
TELEGRAM_CHANNEL_STOCK_TRANSFER=@channel

# Cloudflare R2 (untuk backup storage)
R2_ENDPOINT=https://your-account.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
